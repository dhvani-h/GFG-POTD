class Solution {
public:
    bool canRepresentBST(vector<int>& arr) {
        stack<int> st;
        int lowerBound = 0;

        for (int x : arr) {
            if (x < lowerBound)
                return false;

            while (!st.empty() && x > st.top()) {
                lowerBound = st.top();
                st.pop();
            }

            st.push(x);
        }

        return true;
    }
};
