class Solution {
public:
    int minDeletions(vector<int>& arr) {
        vector<int> temp;

        for (int x : arr) {
            auto it = lower_bound(temp.begin(), temp.end(), x);

            if (it == temp.end())
                temp.push_back(x);
            else
                *it = x;
        }

        return arr.size() - temp.size();
    }
};
